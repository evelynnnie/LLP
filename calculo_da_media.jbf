      </block>
      <block id="8" type="IO">
        <options displayComment="true"/>
        <visual color="255 255 0" posX="-480.0" posY="-10.0"/>
        <content>Writeln("reprovado");	;	</content>
        <comment>"reprovado" </comment>
        <connect ID="12"/>
        <io ioType="1" message="reprovado" messageSuffix="" newLine="true" variable=""/>
      </block>
      <block id="9" type="CPU">
        <options displayComment="false"/>
        <visual color="255 255 0" posX="-480.0" posY="90.0"/>
        <content>mf=(m+af)/2</content>
        <connect ID="10"/>
      </block>
      <block id="10" type="DECISION">
        <options displayComment="false"/>
        <visual color="255 255 0" posX="-480.0" posY="170.0"/>
        <content>mf&lt;=5</content>
        <connect ID="11" value="true"/>
