<?xml version="1.0" encoding="UTF-8"?><JavaBlocks author="Daiane Araujo" scriptEngine="JavaScript" version="6010">
  <option fullConnectorValues="true" grid="false" pascal="false"/>
  <flowchart name="Start">
    <canvas interval="200" posX="0.0" posY="10.0" zoom="3"/>
    <blocks>
      <block id="1" name="Start" type="START">
        <options displayComment="true"/>
        <visual color="255 255 0" posX="0.0" posY="-100.0"/>
        <comment>Start</comment>
        <connect ID="3"/>
      </block>
      <block id="3" type="IO">
        <options displayComment="true"/>
        <visual color="255 255 0" posX="0.0" posY="-10.0"/>
        <content>x=ReadNumber("x?");	;	</content>
        <comment>"x?";	x ;	</comment>
        <connect ID="4"/>
        <io array="0" inputType="0" ioType="2" message="x?" variable="x"/>
      </block>
      <block id="4" type="DECISION">
        <options displayComment="false"/>
        <visual color="255 255 0" posX="0.0" posY="90.0"/>
        <content>x&lt;0</content>
        <connect ID="5" value="true"/>
        <connect ID="7" value="false"/>
      </block>
      <block id="5" type="JUMP">
        <options displayComment="false"/>
        <visual color="255 255 0" posX="-210.0" posY="90.0"/>
        <content> </content>
        <connect ID="6"/>
      </block>
      <block id="6" type="JUMP">
        <options displayComment="false"/>
        <visual color="255 255 0" posX="-210.0" posY="-10.0"/>
        <content> </content>
        <connect ID="3"/>
      </block>
      <block id="7" type="CPU">
        <options displayComment="false"/>
        <visual color="255 255 0" posX="190.0" posY="90.0"/>
        <content>y=x*x</content>
        <connect ID="8"/>
      </block>
      <block id="8" type="IO">
        <options displayComment="true"/>
        <visual color="255 255 0" posX="340.0" posY="90.0"/>
        <content>Writeln("y=" + (getValueOf(y)));	;	</content>
        <comment>"y=" +y</comment>
        <connect ID="10"/>
        <io ioType="1" message="y=" messageSuffix="" newLine="true" variable="y"/>
      </block>
      <block id="10" type="RETURN">
        <options displayComment="true"/>
        <visual color="255 255 0" posX="340.0" posY="-90.0"/>
        <comment>End</comment>
      </block>
    </blocks>
  </flowchart>
</JavaBlocks>
